---
import '../../styles/global.css';
import { destinations, getDestinationBySlug } from '../../data/destinations';

export function getStaticPaths() {
  return destinations.map((destination) => ({
    params: { slug: destination.slug }
  }));
}

const { slug } = Astro.params;
const destination = getDestinationBySlug(slug ?? '');

// Reload fix
if (!destination) {
  return Astro.redirect('/');
}

const phoneRaw = '51928413201';
const waLink = `https://wa.me/${phoneRaw}?text=${encodeURIComponent(
  `Hola JR Transportes, deseo informacion detallada sobre ${destination.name}.`
)}`;
const waRoute = `https://wa.me/${phoneRaw}?text=${encodeURIComponent(
  'Hola JR Transportes, deseo consultar por rutas y horarios.'
)}`;

// Itinerario por defecto para cualquier Tour
const genericTourItinerary = [
  'Punto de encuentro y embarque en la ciudad.',
  'Viaje cómodo con paradas estratégicas y vistas panorámicas del trayecto.',
  'Llegada al atractivo principal, tiempo para conocerlo, fotografías y retorno seguro.'
];

const destinationCopy: Record<string, { heroText: string; itinerary?: string[] }> = {
  'pampa-cangallo': {
    heroText: 'Tierra de los legendarios Morochucos. Vive la experiencia de la libertad andina en las extensas llanuras de Ayacucho.',
  },
  cangallo: {
    heroText: 'La ciudad heroica te espera. Conecta con su historia, su gente y sus paisajes viajando con seguridad.',
  },
  huancasancos: {
    heroText: 'Aventura en altura y rutas de gran valor paisajistico, con servicio responsable de inicio a fin.',
  }
};

const detailCopy = destinationCopy[destination.slug] ?? { heroText: destination.longDescription };
// Usar el predefinido para tours si es un tour
const itineraryList = (destination.category === 'tour') ? genericTourItinerary : [];

const menuLinks = [
  { label: 'Inicio', href: '/' },
  { label: 'Servicios', href: '/#servicios' },
  { label: 'Destinos', href: '/destinos' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contacto', href: '/#contacto' }
];
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{destination.name} | JR Transportes</title>
    <meta
      name="description"
      content={`Detalle de destino ${destination.name}: tarifas referenciales, tiempo estimado y coordinacion por WhatsApp.`}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Manrope:wght@400;500;600;700;800&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@200..700&display=swap"
    />
  </head>
  <body>
    <!-- Header -->
    <header class="andean-border-top sticky top-0 z-50 border-b border-pampa-200/60 bg-pampa-50/80 backdrop-blur-xl">
      <div class="mx-auto flex w-full max-w-6xl items-center justify-between gap-4 px-4 py-2">
        <a href="/" class="no-underline flex items-center -ml-1">
          <img src="/JRlogo.webp" alt="JR Transportes" class="h-14 w-auto object-contain" />
        </a>
        <nav class="hidden items-center gap-6 md:flex" aria-label="Menu principal">
          {menuLinks.map((item) => (
            <a
              href={item.href}
              class:list={[
                "text-sm font-semibold no-underline transition-colors duration-150",
                item.label === 'Destinos'
                  ? "text-pampa-500 border-b border-pampa-500 pb-0.5"
                  : "text-pampa-700/80 hover:text-pampa-500"
              ]}
            >
              {item.label}
            </a>
          ))}
        </nav>
        <div class="flex items-center gap-3">
          <a
            href={waLink}
            target="_blank"
            rel="noopener noreferrer"
            class="hidden rounded-lg bg-logo-500 px-4 py-2 text-sm font-bold text-white no-underline transition-all duration-150 hover:-translate-y-0.5 hover:bg-logo-600 sm:inline-flex"
          >
            Reservar ahora
          </a>
          <button id="menu-toggle" type="button" class="inline-flex items-center justify-center rounded-lg p-2 text-pampa-600 transition-colors hover:bg-pampa-200/50 md:hidden" aria-controls="mobile-menu" aria-expanded="false">
            <span id="menu-icon" class="material-symbols-outlined">menu</span>
          </button>
        </div>
      </div>

      <!-- Menu movil -->
      <nav
        id="mobile-menu"
        class="hidden border-t border-pampa-200/60 bg-pampa-50 px-5 pb-4 pt-2 md:hidden"
        aria-label="Menu movil"
      >
        {menuLinks.map((item) => (
          <a
            href={item.href}
            class="mobile-link block rounded-lg px-3 py-2.5 text-sm font-semibold text-pampa-700 no-underline transition-colors hover:bg-pampa-100"
          >
            {item.label}
          </a>
        ))}
        <a
          class="mt-2 block rounded-lg bg-logo-500 px-3 py-2.5 text-center text-sm font-bold text-white no-underline"
          href={waLink}
          target="_blank"
          rel="noopener noreferrer"
        >
          Reservar ahora
        </a>
      </nav>
    </header>

    <main class="bg-pampa-50">
      <!-- Hero del destino -->
      <section class="relative flex h-[420px] w-full items-end overflow-hidden sm:h-[480px] lg:h-[540px]">
        <img
          src={destination.gallery[0] || destination.image}
          alt={`${destination.name} - Vista de portada`}
          class="absolute inset-0 h-full w-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-pampa-900/85 via-pampa-900/30 to-transparent"></div>

        <div class="relative z-10 mx-auto w-full max-w-6xl px-5 pb-16 sm:pb-20">
          <span class="mb-4 inline-block rounded-full bg-pampa-300 px-4 py-1.5 text-xs font-bold uppercase tracking-[0.12em] text-pampa-800">
            Destino destacado
          </span>
          <h1 class="font-headline text-5xl text-white sm:text-7xl lg:text-8xl">
            {destination.name}
          </h1>
          <p class="mt-4 max-w-lg text-base leading-relaxed text-pampa-100/85 sm:text-lg">
            {detailCopy.heroText}
          </p>
        </div>

        <div class="andean-divider absolute bottom-0 left-0 right-0 opacity-40"></div>
      </section>

      <!-- Stats bar -->
      <div class="relative z-10 mx-auto -mt-12 max-w-6xl px-5">
        <div class="grid grid-cols-1 gap-5 rounded-2xl border border-pampa-200/50 bg-white p-6 shadow-card sm:grid-cols-2 sm:p-7 lg:grid-cols-4">
          <div class="flex items-center gap-3">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-cielo-50 text-cielo-500">
              <span class="material-symbols-outlined text-xl">schedule</span>
            </div>
            <div>
              <p class="text-[10px] font-bold uppercase tracking-widest text-pampa-600/50">Duracion</p>
              <p class="text-sm font-bold text-pampa-800">{destination.travelTime}</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-cielo-50 text-cielo-500">
              <span class="material-symbols-outlined text-xl">directions_car</span>
            </div>
            <div>
              <p class="text-[10px] font-bold uppercase tracking-widest text-pampa-600/50">Transporte</p>
              <p class="text-sm font-bold text-pampa-800">Vehículos modernos</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-cielo-50 text-cielo-500">
              <span class="material-symbols-outlined text-xl">location_on</span>
            </div>
            <div>
              <p class="text-[10px] font-bold uppercase tracking-widest text-pampa-600/50">Salida</p>
              <p class="text-sm font-bold text-pampa-800">Terminal Terrestre de Ayacucho</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-pampa-100 text-pampa-500">
              <span class="material-symbols-outlined text-xl">payments</span>
            </div>
            <div>
              <p class="text-[10px] font-bold uppercase tracking-widest text-pampa-600/50">Desde</p>
              <p class="text-sm font-bold text-pampa-600">{destination.price}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Contenido principal -->
      <section class="mx-auto grid max-w-6xl grid-cols-1 gap-10 px-5 py-16 sm:py-20 md:grid-cols-[1fr_340px]">
        <!-- Columna principal -->
        <div class="space-y-14">
          <!-- Galeria Inteligente -->
          {destination.gallery && destination.gallery.length > 0 && (
            <div>
              <h2 class="mb-6 flex items-center gap-3 font-headline text-2xl text-pampa-900 sm:text-3xl">
                <span class="h-0.5 w-6 rounded-full bg-pampa-400"></span>
                Capturando la esencia
              </h2>
              {destination.gallery.length >= 3 ? (
                <div class="grid h-[300px] grid-cols-12 gap-3 sm:h-[450px] lg:h-[520px]">
                  <div class="group relative col-span-8 overflow-hidden rounded-xl bg-pampa-200">
                    <img
                      src={destination.gallery[0]}
                      alt={`${destination.name} - Vista principal`}
                      class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    />
                  </div>
                  <div class="col-span-4 grid grid-rows-2 gap-3">
                    <div class="group relative overflow-hidden rounded-xl bg-pampa-200">
                      <img
                        src={destination.gallery[1]}
                        alt={`${destination.name} - Detalle 1`}
                        class="absolute inset-0 h-full w-full object-cover object-center transition-transform duration-500 group-hover:scale-105"
                      />
                    </div>
                    <div class="group relative overflow-hidden rounded-xl bg-pampa-200">
                      <img
                        src={destination.gallery[2]}
                        alt={`${destination.name} - Detalle 2`}
                        class="absolute inset-0 h-full w-full object-cover object-center transition-transform duration-500 group-hover:scale-105"
                      />
                    </div>
                  </div>
                </div>
              ) : (
                <div class="group relative h-[300px] w-full overflow-hidden rounded-xl sm:h-[450px] bg-pampa-200">
                  <img
                    src={destination.gallery[0] || destination.image}
                    alt={`${destination.name} - Vista principal`}
                    class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                </div>
              )}
            </div>
          )}

          <!-- Timeline del viaje (Solo para Tours) -->
          {destination.category === 'tour' && (
            <div class="rounded-2xl bg-pampa-100 p-7 sm:p-10">
              <h2 class="mb-8 font-headline text-2xl text-pampa-900 sm:text-3xl">Tu viaje con nosotros</h2>
              <div class="space-y-8">
                {itineraryList.map((step: string, index: number) => (
                  <div class="flex gap-5">
                    <div class="flex flex-col items-center">
                      <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-pampa-500 text-sm font-bold text-white">
                        {index + 1}
                      </div>
                      {index < itineraryList.length - 1 && (
                        <div class="my-1.5 w-px flex-1 bg-pampa-300/40"></div>
                      )}
                    </div>
                    <div class="pb-2">
                      <h3 class="font-headline text-lg text-pampa-800">Etapa {index + 1}</h3>
                      <p class="mt-1 text-sm leading-relaxed text-pampa-700/70">{step}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>

        <!-- Sidebar -->
        <div class="space-y-5">
          <!-- Card de reserva -->
          <div class="andean-border-top rounded-2xl border border-pampa-200/50 bg-white p-6 shadow-card">
            <p class="mb-1.5 text-[10px] font-bold uppercase tracking-widest text-pampa-600/50">Precio por persona</p>
            <div class="mb-6 flex items-baseline gap-2">
              <span class="font-headline text-4xl text-pampa-800">{destination.price.replace('Desde ', '')}</span>
              <span class="text-sm text-pampa-600/50">/ referencial</span>
            </div>

            <div class="mb-6 space-y-3">
              {destination.highlights.map((item) => (
                <div class="flex items-center gap-2.5 text-pampa-800">
                  <span class="material-symbols-outlined text-lg text-pampa-500">check_circle</span>
                  <span class="text-sm font-medium">{item}</span>
                </div>
              ))}
            </div>

            <a
              href={waLink}
              target="_blank"
              rel="noopener noreferrer"
              class="flex w-full items-center justify-center gap-2 rounded-xl bg-quebrada-500 py-3.5 text-center text-sm font-bold text-white no-underline transition-all duration-150 hover:-translate-y-0.5 hover:bg-quebrada-400"
            >
              <span class="material-symbols-outlined text-lg">chat</span>
              Reservar por WhatsApp
            </a>

            <p class="mt-4 text-center text-[11px] font-medium text-pampa-600/50">Atencion inmediata al 918 712 309</p>
            <p class="mt-1 text-center text-[11px] font-medium text-pampa-600/50">Horario: 5:00 am - 7:00 pm</p>
          </div>

          <!-- Card de seguridad -->
          <div class="overflow-hidden rounded-2xl bg-cielo-700 p-6 text-white">
            <h3 class="mb-3 font-headline text-lg text-white">Viaja con seguridad</h3>
            <p class="mb-5 text-sm leading-relaxed text-white/80">
              Nuestra prioridad es tu tranquilidad. Todas nuestras unidades cuentan con tecnologia de punta.
            </p>
            <div class="space-y-3">
              <div class="flex items-center gap-3 rounded-lg bg-white/10 p-3">
                <span class="material-symbols-outlined text-lg text-pampa-300">verified_user</span>
                <span class="text-sm font-semibold">Seguro de viaje SOAT</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Seccion de flota -->
      <section class="mx-auto max-w-6xl px-5 pb-16 sm:pb-20">
        <div class="grid grid-cols-1 overflow-hidden rounded-2xl bg-pampa-100 lg:grid-cols-2">
          <div class="flex flex-col justify-center p-10 lg:p-14">
            <h2 class="mb-4 font-headline text-3xl text-pampa-900 sm:text-4xl">Nuestra flota moderna</h2>
            <p class="mb-6 text-sm leading-relaxed text-pampa-700/70">
              Viaja con la comodidad que mereces. Nuestras unidades estan equipadas
              con aire acondicionado, asientos ergonomicos y espacio para equipaje.
            </p>
            <div class="flex flex-wrap gap-3">
              <div class="flex items-center gap-2 rounded-full border border-pampa-200 bg-white px-3 py-1.5 text-xs font-bold text-pampa-700">
                <span class="material-symbols-outlined text-base text-pampa-500">ac_unit</span>
                Aire acondicionado
              </div>
              <div class="flex items-center gap-2 rounded-full border border-pampa-200 bg-white px-3 py-1.5 text-xs font-bold text-pampa-700">
                <span class="material-symbols-outlined text-base text-pampa-500">wifi</span>
                Entretenimiento
              </div>
            </div>
          </div>
          <div class="relative min-h-[320px]">
            <img
              src={destination.fleetImage}
              alt="Flota de vehículos modernos recorriendo destinos andinos"
              class="h-full w-full object-cover"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-r from-pampa-100 via-transparent to-transparent"></div>
          </div>
        </div>
      </section>
    </main>

    <!-- Footer -->
    <footer style="background-color: #0D1E30; border-top: 1px solid rgba(255,255,255,0.15);" class="py-8">
      <div class="mx-auto flex w-full max-w-6xl flex-col items-center justify-between gap-4 px-5 sm:flex-row">
        <div>
          <p class="font-headline text-base" style="color: #ffffff;">JR Transportes</p>
          <p class="mt-0.5 text-xs" style="color: rgba(255,255,255,0.6);">&copy; {new Date().getFullYear()} JR Transportes. Ayacucho, Peru.</p>
        </div>
        <div class="flex gap-5">
          <a href="#" class="text-xs font-semibold no-underline" style="color: rgba(255,255,255,0.75);">Terminos</a>
          <a href="#" class="text-xs font-semibold no-underline" style="color: rgba(255,255,255,0.75);">Privacidad</a>
          <a
            href={waRoute}
            target="_blank"
            rel="noopener noreferrer"
            class="text-xs font-semibold no-underline"
            style="color: rgba(255,255,255,0.75);"
          >
            WhatsApp
          </a>
        </div>
      </div>
    </footer>

    <!-- Boton flotante WhatsApp -->
    <a
      class="fixed bottom-5 right-5 z-40 flex items-center gap-2 rounded-full bg-quebrada-500 px-4 py-3 text-sm font-bold text-white no-underline shadow-float transition-all duration-200 hover:-translate-y-0.5 hover:bg-quebrada-400"
      href={waLink}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Abrir WhatsApp"
    >
      <span class="material-symbols-outlined text-lg">chat</span>
      WhatsApp
    </a>

    <script>
      // Menu hamburguesa
      const toggle = document.getElementById('menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      const mobileIcon = document.getElementById('menu-icon');

      if (toggle && mobileMenu && mobileIcon) {
        toggle.addEventListener('click', () => {
          const open = mobileMenu.classList.toggle('hidden');
          mobileIcon.textContent = open ? 'menu' : 'close';
          toggle.setAttribute('aria-expanded', String(!open));
        });

        mobileMenu.querySelectorAll('.mobile-link').forEach((link) => {
          link.addEventListener('click', () => {
            mobileMenu.classList.add('hidden');
            mobileIcon.textContent = 'menu';
            toggle.setAttribute('aria-expanded', 'false');
          });
        });
      }
    </script>
  </body>
</html>
