---
import Layout from '../../components/Layout.astro';
import '../../styles/global.css';
import { destinations } from '../../data/destinations';

const destinosList = destinations.filter((d) => d.category === 'destino' || !d.category);
const toursList = destinations.filter((d) => d.category === 'tour');

const phoneRaw = '51928413201';
const whatsappBase = `https://wa.me/${phoneRaw}`;

const waRoute = `${whatsappBase}?text=${encodeURIComponent(
  'Hola JR Transportes, deseo consultar por rutas y horarios.'
)}`;

const localBusinessSchema = {
  "@context": 'https://schema.org',
  "@type": 'TravelAgency',
  name: 'JR Transportes',
  telephone: `+${phoneRaw}`,
  areaServed: 'Ayacucho, Peru'
};
---

<Layout
  title="Destinos y Tours en Ayacucho | JR Transportes"
  description="Explora nuestros destinos interprovinciales y tours turisticos en Ayacucho. Cangallo, Pampa Cangallo, Huancasancos, Aguas Turquesas de Millpu, Pachapupum y mas."
  keywords="destinos Ayacucho, tours Ayacucho, viajes Cangallo, Pampa Cangallo, Huancasancos, Aguas Turquesas de Millpu, Pachapupum, cataratas Pumapaqcha, turismo Ayacucho, que hacer en Ayacucho"
  ogTitle="Destinos y Tours en Ayacucho | JR Transportes"
  ogDescription="Explora nuestros destinos interprovinciales y tours turisticos en Ayacucho. Cangallo, Pampa Cangallo, Huancasancos y mas."
  ogType="website"
  ogImage="https://jrtransportesmorochucos.com/images/Pampa%20cangallo/pampa-cangallo.webp"
  schema={localBusinessSchema}
  activePage="destinos"
  ctaText="Reservar ahora"
  ctaHref={waRoute}
  bodyClass="bg-pampa-100 selection:bg-pampa-300 selection:text-pampa-900"
>
  <div class="noise-overlay"></div>
  
  <!-- Hero de Destinos -->
  <section class="relative flex h-[320px] w-full items-end overflow-hidden sm:h-[380px] lg:h-[440px]">
    <img
      src="https://lh3.googleusercontent.com/aida-public/AB6AXuDY7u1kL2Z1wZDsppmSkekS25Q5CEUM500ZfM0TwbLpuE9JB1NCTr6Yl8adRmLAk6icC0aC6oCBUzVdrb18-k2Dj6NyJGsrHtHsmsiZ3hVX6zjUx-Zz-oPShMrtGU81Sk4g72Yj2x2vYQeAcsfdzfBdtHDc5oiHmtSnM7WUkSYdrNAXvVAETkwWkgmiFVZuvLk7Dh5AcOTT7GlKyytJrCI_OkgoIxTcpjnCVzL3E4Bv2VGXudL3Y5cV6UilB4F_uGpFfrjEQHG6pw"
      alt="Paisaje andino de Ayacucho"
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="page-hero-overlay absolute inset-0 bg-gradient-to-t from-pampa-900/85 via-pampa-900/30 to-transparent"></div>

    <div class="relative z-10 mx-auto w-full max-w-6xl px-5 pb-14 sm:pb-16">
      <span class="mb-3 inline-block rounded-full bg-pampa-300 px-4 py-1.5 text-xs font-bold uppercase tracking-[0.12em] text-pampa-800">
        Nuestras rutas
      </span>
      <h1 class="font-headline text-4xl text-white sm:text-5xl lg:text-6xl">
        Destinos y Tours
      </h1>
      <p class="mt-3 max-w-lg text-base leading-relaxed text-pampa-100/85">
        Descubre cada rincón de Ayacucho con nosotros. Rutas interprovinciales y experiencias turísticas únicas.
      </p>
    </div>

    <div class="andean-divider absolute bottom-0 left-0 right-0 opacity-40"></div>
  </section>

  <!-- Seccion Destinos Interprovinciales -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto w-full max-w-6xl px-5">
      <div class="mb-10 text-center">
        <p class="mb-2 text-xs font-bold uppercase tracking-[0.15em] text-pampa-500">Transporte regular</p>
        <h2 class="font-headline text-3xl text-pampa-900 sm:text-4xl">Destinos interprovinciales</h2>
        <div class="andean-divider mx-auto mt-4 max-w-[120px]"></div>
      </div>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {destinosList.map((destination, i) => (
          <article class={`fade-in-up stagger-${i + 1} group flex flex-col overflow-hidden rounded-xl border border-pampa-200/50 bg-white shadow-soft transition-all duration-300 hover:-translate-y-2 hover:shadow-float`}>
            <div class="relative h-52 overflow-hidden">
              <img
                src={destination.image}
                alt={destination.name}
                class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
                loading="lazy"
              />
              <span class="absolute right-3 top-3 z-10 rounded-full bg-pampa-50/95 px-3 py-1 text-xs font-extrabold text-pampa-600 shadow-soft backdrop-blur-md">
                {destination.price}
              </span>
            </div>
            <div class="flex flex-1 flex-col justify-between p-5">
              <div>
                <h3 class="font-headline text-xl text-pampa-800">{destination.name}</h3>
                <p class="mt-2 text-sm leading-relaxed text-pampa-700/70">{destination.description}</p>
              </div>
              <div class="mt-4 flex items-center justify-between">
                <span class="text-xs font-bold uppercase tracking-widest text-pampa-500">{destination.travelTime}</span>
                <a
                  class="inline-flex items-center gap-1 text-sm font-bold text-cielo-500 no-underline transition-all hover:gap-2 hover:text-cielo-700"
                  href={`/destinos/${destination.slug}`}
                >
                  Ver detalle
                  <span class="material-symbols-outlined text-base">arrow_forward</span>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Seccion Tours Turisticos -->
  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto w-full max-w-6xl px-5">
      <div class="mb-10 text-center">
        <p class="mb-2 text-xs font-bold uppercase tracking-[0.15em] text-pampa-500">Experiencias</p>
        <h2 class="font-headline text-3xl text-pampa-900 sm:text-4xl">Tours turisticos</h2>
        <div class="andean-divider mx-auto mt-4 max-w-[120px]"></div>
      </div>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {toursList.map((tour, i) => (
          <article class={`fade-in-up stagger-${i + 1} group flex flex-col overflow-hidden rounded-xl border border-pampa-200/50 bg-pampa-50 shadow-soft transition-all duration-300 hover:-translate-y-2 hover:shadow-float`}>
            <div class="relative h-52 overflow-hidden">
              <img
                src={tour.image}
                alt={tour.name}
                class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
                loading="lazy"
              />
              <span class="absolute left-3 top-3 z-10 rounded-full bg-cielo-700/90 px-3 py-1 text-xs font-extrabold text-white shadow-soft backdrop-blur-md">
                Tour
              </span>
            </div>
            <div class="flex flex-1 flex-col justify-between p-5">
              <div>
                <h3 class="font-headline text-xl text-pampa-800">{tour.name}</h3>
                <p class="mt-2 text-sm leading-relaxed text-pampa-700/70 line-clamp-3">{tour.description}</p>
              </div>
              <div class="mt-4 flex items-center justify-between">
                <span class="text-xs font-bold uppercase tracking-widest text-pampa-500">{tour.travelTime}</span>
                <a
                  class="inline-flex items-center gap-1 text-sm font-bold text-cielo-500 no-underline transition-all hover:gap-2 hover:text-cielo-700"
                  href={`/destinos/${tour.slug}`}
                >
                  Ver tour
                  <span class="material-symbols-outlined text-base">arrow_forward</span>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Boton flotante WhatsApp -->
  <a
    slot="after-footer"
    class="fixed bottom-5 right-5 z-40 flex items-center gap-2 rounded-full bg-quebrada-500 px-4 py-3 text-sm font-bold text-white no-underline shadow-float transition-all duration-200 hover:-translate-y-0.5 hover:bg-quebrada-400 hover:shadow-elevated"
    href={waRoute}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Abrir WhatsApp"
  >
    <span class="material-symbols-outlined text-lg">chat</span>
    WhatsApp
  </a>
</Layout>
