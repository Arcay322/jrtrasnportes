---
import '../../styles/global.css';
import { destinations } from '../../data/destinations';

const destinosList = destinations.filter((d) => d.category === 'destino' || !d.category);
const toursList = destinations.filter((d) => d.category === 'tour');

const companyName = 'JR Transportes';
const phoneRaw = '51918712309';
const whatsappBase = `https://wa.me/${phoneRaw}`;

const waRoute = `${whatsappBase}?text=${encodeURIComponent(
  'Hola JR Transportes, deseo consultar por rutas y horarios.'
)}`;

const menuLinks = [
  { label: 'Inicio', href: '/' },
  { label: 'Servicios', href: '/#servicios' },
  { label: 'Destinos', href: '/destinos' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contacto', href: '#contacto' }
];

const localBusinessSchema = {
  "@context": 'https://schema.org',
  "@type": 'TravelAgency',
  name: companyName,
  telephone: `+${phoneRaw}`,
  areaServed: 'Ayacucho, Peru'
};
---

<html lang="es">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Destinos y Tours | JR Transportes</title>
  <meta name="description" content="Explora nuestras rutas interprovinciales y servicios turísticos guiados por todo Ayacucho." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Manrope:wght@400;500;600;700;800&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@200..700&display=swap" />
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)}></script>
</head>
<body class="bg-pampa-100 selection:bg-pampa-300 selection:text-pampa-900">
  <div class="noise-overlay"></div>
  <a class="skip-link" href="#contenido">Saltar al contenido</a>

  <!-- Header -->
  <header class="andean-border-top sticky top-0 z-50 border-b border-pampa-200/60 bg-pampa-50/80 backdrop-blur-xl">
    <div class="mx-auto flex w-full max-w-6xl items-center justify-between gap-4 px-4 py-2">
      <a href="/" class="no-underline flex items-center -ml-1">
        <img src="/JRlogo.webp" alt="JR Transportes" class="h-14 w-auto object-contain" />
      </a>
      <!-- Navegacion desktop -->
      <nav class="hidden items-center gap-6 md:flex" aria-label="Menu principal">
        {menuLinks.map((item) => (
          <a href={item.href} class="text-sm font-semibold text-pampa-700/80 no-underline transition-colors duration-150 hover:text-pampa-500">
            {item.label}
          </a>
        ))}
      </nav>
      <div class="flex items-center gap-3">
        <a class="hidden rounded-lg bg-logo-500 px-4 py-2 text-sm font-bold text-white no-underline transition-all duration-150 hover:-translate-y-0.5 hover:bg-logo-600 hover:shadow-elevated sm:inline-flex" href={waRoute} target="_blank" rel="noopener noreferrer">
          Contactar
        </a>
        <button id="menu-toggle" type="button" class="inline-flex items-center justify-center rounded-lg p-2 text-pampa-600 transition-colors hover:bg-pampa-200/50 md:hidden" aria-controls="mobile-menu" aria-expanded="false">
          <span id="menu-icon" class="material-symbols-outlined">menu</span>
        </button>
      </div>
    </div>

    <!-- Menu movil -->
    <nav
      id="mobile-menu"
      class="hidden border-t border-pampa-200/60 bg-pampa-50 px-5 pb-4 pt-2 md:hidden"
      aria-label="Menu movil"
    >
      {menuLinks.map((item) => (
        <a
          href={item.href}
          class="mobile-link block rounded-lg px-3 py-2.5 text-sm font-semibold text-pampa-700 no-underline transition-colors hover:bg-pampa-100"
        >
          {item.label}
        </a>
      ))}
      <a
        class="mt-2 block rounded-lg bg-logo-500 px-3 py-2.5 text-center text-sm font-bold text-white no-underline"
        href={waRoute}
        target="_blank"
        rel="noopener noreferrer"
      >
        Contactar
      </a>
    </nav>
  </header>

  <main id="contenido" class="min-h-screen pt-4 pb-16">
    <div class="mx-auto max-w-6xl px-5">
      <!-- Title -->
      <div class="mb-12 text-center fade-in-up">
        <h1 class="mb-4 font-headline text-4xl text-pampa-900 sm:text-5xl lg:text-6xl">Nuestro Catálogo</h1>
        <p class="mx-auto max-w-2xl text-lg text-pampa-700/80">
          Elige la mejor forma de viajar. Transpórtate con seguridad de una ciudad a otra, o descubre las maravillas de Ayacucho con nuestros paseos turísticos.
        </p>
      </div>

      <!-- Tabs Toggle -->
      <div class="mb-12 flex justify-center fade-in-up">
        <div class="inline-flex rounded-full bg-white p-1.5 shadow-sm border border-pampa-200">
          <button id="tab-btn-destinos" class="tab-btn rounded-full px-6 py-2.5 text-sm font-bold transition-all bg-pampa-800 text-white shadow-md">
            Destinos Locales
          </button>
          <button id="tab-btn-tours" class="tab-btn rounded-full px-6 py-2.5 text-sm font-bold transition-all text-pampa-600 hover:text-pampa-900">
            Tours Turísticos
          </button>
        </div>
      </div>

      <!-- Vista: Destinos -->
      <section id="grid-destinos" class="fade-in-up transition-opacity duration-300">
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {destinosList.map((dest) => (
            <a href={`/destinos/${dest.slug}`} class="group relative flex h-[400px] w-full flex-col justify-end overflow-hidden rounded-2xl no-underline">
              <img src={dest.image} alt={dest.name} loading="lazy" class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105" />
              <div class="absolute inset-0 bg-gradient-to-t from-pampa-900/90 via-pampa-900/40 to-transparent"></div>
              
              <div class="relative z-10 flex flex-col p-6">
                <div class="mb-3">
                  <span class="inline-block rounded-md bg-white/20 px-3 py-1 text-[11px] font-bold uppercase tracking-widest text-white backdrop-blur-md">Ruta diaria</span>
                </div>
                <h3 class="font-headline text-3xl font-normal tracking-tight text-white">{dest.name}</h3>
                <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-white/80">{dest.description}</p>
                
                <div class="mt-5 flex items-center justify-between border-t border-white/15 pt-4">
                  <div>
                    <p class="text-[10px] font-bold uppercase tracking-widest text-white/50">Viaje desde</p>
                    <p class="text-base font-bold text-white">{dest.price}</p>
                  </div>
                  <div class="flex h-10 w-10 items-center justify-center rounded-full bg-pampa-300 text-pampa-900 transition-transform duration-300 group-hover:translate-x-1 group-hover:bg-white">
                    <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- Vista: Tours -->
      <section id="grid-tours" class="hidden fade-in-up transition-opacity duration-300">
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {toursList.map((dest) => (
            <a href={`/destinos/${dest.slug}`} class="group relative flex h-[400px] w-full flex-col justify-end overflow-hidden rounded-2xl no-underline">
              <img src={dest.image} alt={dest.name} loading="lazy" class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105" />
              <div class="absolute inset-0 bg-gradient-to-t from-pampa-900/95 via-pampa-900/50 to-transparent"></div>
              
              <div class="relative z-10 flex flex-col p-6">
                <div class="mb-3">
                  <span class="inline-block rounded-md bg-cielo-500/80 px-3 py-1 text-[11px] font-bold uppercase tracking-widest text-white backdrop-blur-md">Tour guiado</span>
                </div>
                <h3 class="font-headline text-3xl font-normal tracking-tight text-white">{dest.name}</h3>
                <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-white/80">{dest.description}</p>
                
                <div class="mt-5 flex items-center justify-between border-t border-white/15 pt-4">
                  <div>
                    <p class="text-[10px] font-bold uppercase tracking-widest text-white/50">Por persona</p>
                    <p class="text-base font-bold text-white">{dest.price}</p>
                  </div>
                  <div class="flex h-10 w-10 items-center justify-center rounded-full bg-cielo-500 text-white transition-transform duration-300 group-hover:translate-x-1">
                    <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    </div>
  </main>

  <footer id="contacto" class="border-t border-pampa-50/15 bg-cielo-900 py-8">
    <div class="mx-auto flex w-full max-w-6xl flex-col items-center justify-between gap-4 px-5 sm:flex-row">
      <div>
        <p class="font-headline text-base text-pampa-50">JR Transportes</p>
        <p class="mt-0.5 text-xs text-pampa-50/60">&copy; {new Date().getFullYear()} JR Transportes. Ayacucho, Peru.</p>
      </div>
    </div>
  </footer>

  <script>
    // Menu hamburguesa
    const toggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileIcon = document.getElementById('menu-icon');

    if (toggle && mobileMenu && mobileIcon) {
      toggle.addEventListener('click', () => {
        const open = mobileMenu.classList.toggle('hidden');
        mobileIcon.textContent = open ? 'menu' : 'close';
        toggle.setAttribute('aria-expanded', String(!open));
      });

      mobileMenu.querySelectorAll('.mobile-link').forEach((link) => {
        link.addEventListener('click', () => {
          mobileMenu.classList.add('hidden');
          mobileIcon.textContent = 'menu';
          toggle.setAttribute('aria-expanded', 'false');
        });
      });
    }

    // Tab switching logic
    const tabDestinos = document.getElementById('tab-btn-destinos');
    const tabTours = document.getElementById('tab-btn-tours');
    const gridDestinos = document.getElementById('grid-destinos');
    const gridTours = document.getElementById('grid-tours');

    if (tabDestinos && tabTours && gridDestinos && gridTours) {
      tabDestinos.addEventListener('click', () => {
        // Toggle Buttons
        tabDestinos.className = "tab-btn rounded-full px-6 py-2.5 text-sm font-bold transition-all bg-pampa-800 text-white shadow-md";
        tabTours.className = "tab-btn rounded-full px-6 py-2.5 text-sm font-bold transition-all text-pampa-600 hover:text-pampa-900";
        // Toggle Grids
        gridDestinos.classList.remove('hidden');
        gridTours.classList.add('hidden');
      });

      tabTours.addEventListener('click', () => {
        // Toggle Buttons
        tabTours.className = "tab-btn rounded-full px-6 py-2.5 text-sm font-bold transition-all bg-pampa-800 text-white shadow-md";
        tabDestinos.className = "tab-btn rounded-full px-6 py-2.5 text-sm font-bold transition-all text-pampa-600 hover:text-pampa-900";
        // Toggle Grids
        gridTours.classList.remove('hidden');
        gridDestinos.classList.add('hidden');
      });
    }

    // Intersection Observer for animations
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.fade-in-up').forEach((el) => observer.observe(el));
  </script>
</body>
</html>
