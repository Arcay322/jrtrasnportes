---
import '../../styles/global.css';

export async function getStaticPaths() {
  const rawPosts = import.meta.glob('../../data/blog/*.md', { eager: true });
  const posts = Object.values(rawPosts) as any[];
  return posts.map(post => ({
    params: { slug: post.frontmatter.slug },
    props: { post, allPosts: posts },
  }));
}

const { post } = Astro.props as { post: any };
const { Content } = post;

const rawPosts = import.meta.glob('../../data/blog/*.md', { eager: true });
const allPosts = Object.values(rawPosts) as any[];
const recentPosts = allPosts.filter(p => p.frontmatter.slug !== post.frontmatter.slug).slice(0, 3);

const phoneRaw = '51918712309';
const whatsappBase = `https://wa.me/${phoneRaw}`;
const waRoute = `${whatsappBase}?text=${encodeURIComponent(
  `Hola JR Transportes, estuve leyendo el articulo "${post.frontmatter.title}" y deseo mas información.`
)}`;

const menuLinks = [
  { label: 'Inicio', href: '/' },
  { label: 'Servicios', href: '/#servicios' },
  { label: 'Destinos', href: '/destinos' },
  { label: 'Blog', href: '/blog' }
];
---

<html lang="es">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{post.frontmatter.title} | Blog JR Transportes</title>
  <meta name="description" content={post.frontmatter.description} />
  
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Manrope:wght@400;500;600;700;800&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@200..700&display=swap" />
  
  <!-- CSS global inyectado localmente para dar estilo al Markdown -->
  <style is:global>
    .markdown-content h2 {
      font-family: 'DM Serif Display', serif;
      font-size: 1.875rem;
      color: #1a2432; /* pampa-900 aprox */
      margin-top: 2rem;
      margin-bottom: 1rem;
      line-height: 1.2;
    }
    .markdown-content p {
      margin-bottom: 1.25rem;
      line-height: 1.75;
      font-size: 1rem;
      color: #3b4b5e; /* pampa-700/80 aprox */
    }
    .markdown-content ul {
      list-style-type: disc;
      padding-left: 1.5rem;
      margin-bottom: 1.25rem;
      color: #3b4b5e;
    }
    .markdown-content li {
      margin-bottom: 0.5rem;
    }
    .markdown-content strong {
      font-weight: 700;
      color: #1a2432;
    }
    .markdown-content em {
      font-style: italic;
    }
  </style>
</head>
<body class="bg-white selection:bg-pampa-300 selection:text-pampa-900">
  <div class="noise-overlay"></div>

  <header class="andean-border-top sticky top-0 z-50 border-b border-pampa-200/60 bg-pampa-50/80 backdrop-blur-xl">
    <div class="mx-auto flex w-full max-w-6xl items-center justify-between gap-4 px-4 py-2">
      <a href="/" class="no-underline flex items-center -ml-1">
        <img src="/JRlogo.webp" alt="JR Transportes" class="h-14 w-auto object-contain" />
      </a>
      <nav class="hidden items-center gap-6 md:flex" aria-label="Menu principal">
        {menuLinks.map((item) => (
          <a href={item.href} class="text-sm font-semibold text-pampa-700/80 no-underline transition-colors duration-150 hover:text-pampa-500">
            {item.label}
          </a>
        ))}
      </nav>
      <div class="flex items-center gap-3">
        <a class="hidden rounded-lg bg-logo-500 px-4 py-2 text-sm font-bold text-white no-underline transition-all duration-150 hover:-translate-y-0.5 hover:bg-logo-600 hover:shadow-elevated sm:inline-flex" href={waRoute} target="_blank" rel="noopener noreferrer">
          Contactar
        </a>
        <button id="menu-toggle" type="button" class="inline-flex items-center justify-center rounded-lg p-2 text-pampa-600 transition-colors hover:bg-pampa-200/50 md:hidden" aria-controls="mobile-menu" aria-expanded="false">
          <span id="menu-icon" class="material-symbols-outlined">menu</span>
        </button>
      </div>
    </div>

    <!-- Menu movil -->
    <nav
      id="mobile-menu"
      class="hidden border-t border-pampa-200/60 bg-pampa-50 px-5 pb-4 pt-2 md:hidden"
      aria-label="Menu movil"
    >
      {menuLinks.map((item) => (
        <a
          href={item.href}
          class="mobile-link block rounded-lg px-3 py-2.5 text-sm font-semibold text-pampa-700 no-underline transition-colors hover:bg-pampa-100"
        >
          {item.label}
        </a>
      ))}
      <a
        class="mt-2 block rounded-lg bg-logo-500 px-3 py-2.5 text-center text-sm font-bold text-white no-underline"
        href={waRoute}
        target="_blank"
        rel="noopener noreferrer"
      >
        Contactar
      </a>
    </nav>
  </header>

  <main class="min-h-screen pb-16 pt-4 mt-2">
    <div class="mx-auto flex max-w-6xl flex-col items-start gap-10 px-5 lg:flex-row lg:gap-12">
      <!-- Contenido Principal -->
      <article class="w-full flex-1 max-w-3xl">
        
        <!-- Cabecera del articulo -->
        <header class="mb-10 fade-in-up">
          <span class="mb-4 inline-block rounded-full bg-pampa-100 px-4 py-1 text-xs font-bold uppercase tracking-widest text-pampa-600">
            En ruta
          </span>
          <h1 class="mb-6 font-headline text-4xl leading-tight text-pampa-900 sm:text-5xl lg:text-6xl">
            {post.frontmatter.title}
          </h1>
          <div class="flex items-center gap-4 text-sm font-semibold text-pampa-500">
            <span>Por {post.frontmatter.author}</span>
            <span class="h-1 w-1 rounded-full bg-pampa-300"></span>
            <span>{new Date(post.frontmatter.date).toLocaleDateString('es-PE', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          </div>
        </header>

        <!-- Imagen Destacada -->
        <div class="mb-12 overflow-hidden rounded-2xl shadow-card fade-in-up">
          <img 
            src={post.frontmatter.image} 
            alt={post.frontmatter.title} 
            class="aspect-[16/9] w-full object-cover sm:aspect-[2/1]" 
          />
        </div>

        <!-- Contenido -->
        <div class="markdown-content fade-in-up">
          <Content />
        </div>

        <!-- CTA Inmersivo al finalizar lectura -->
        <div class="mt-16 rounded-2xl bg-cielo-700 p-8 text-center text-white md:p-10 fade-in-up">
          <h3 class="mb-3 font-headline text-3xl">¿Listo para viajar?</h3>
          <p class="mb-6 mx-auto max-w-xl text-white/80">Si este articulo te animó a empacar maletas, escríbenos a nuestro canal directo y reserva tus pasajes hoy.</p>
          <a
            href={waRoute}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-xl bg-pampa-300 px-8 py-4 text-base font-extrabold text-cielo-900 no-underline shadow-soft transition-all duration-200 hover:-translate-y-1 hover:bg-pampa-400"
          >
            <span class="material-symbols-outlined text-xl">chat</span>
            Conversar en WhatsApp
          </a>
        </div>
      </article>

      <!-- Sidebar Lateral -->
      <aside class="sticky top-28 hidden w-full shrink-0 flex-col gap-8 lg:flex lg:w-[320px]">
        <!-- Tarjeta de Autor u Operador -->
        <div class="rounded-2xl border border-pampa-200/50 bg-white p-6 shadow-soft fade-in-up">
          <div class="mb-4 flex items-center gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-pampa-100 text-pampa-600">
              <span class="material-symbols-outlined">directions_bus</span>
            </div>
            <div>
              <p class="font-headline text-lg text-pampa-900">JR Transportes</p>
              <p class="text-xs font-bold uppercase tracking-widest text-cielo-600">Tu agencia oficial</p>
            </div>
          </div>
          <p class="text-sm leading-relaxed text-pampa-700/80">
            Somos especialistas en rutas ayacuchanas. Más de una década transportando sueños con seguridad.
          </p>
          <div class="mt-5 border-t border-pampa-100 pt-4">
            <a href={waRoute} target="_blank" class="flex w-full items-center justify-center gap-2 rounded-lg bg-quebrada-500 py-2.5 text-sm font-bold text-white transition-colors hover:bg-quebrada-600">
              <span class="material-symbols-outlined text-[18px]">chat</span> Enviar mensaje
            </a>
          </div>
        </div>

        <!-- Casilla de Otros Artículos -->
        {recentPosts.length > 0 && (
          <div class="rounded-2xl border border-pampa-200/50 bg-white p-6 shadow-soft fade-in-up">
            <h3 class="mb-4 font-headline text-xl text-pampa-900">Tambien  te puede interesar</h3>
            <div class="flex flex-col gap-4">
              {recentPosts.map((relatedPost: any) => (
                <a href={`/blog/${relatedPost.frontmatter.slug}`} class="group flex gap-3 no-underline">
                  <div class="h-16 w-20 shrink-0 overflow-hidden rounded-md">
                    <img src={relatedPost.frontmatter.image} alt={relatedPost.frontmatter.title} class="h-full w-full object-cover transition-transform group-hover:scale-110" />
                  </div>
                  <div class="flex flex-1 flex-col justify-center">
                    <h4 class="line-clamp-2 text-sm font-bold leading-tight text-pampa-800 transition-colors group-hover:text-cielo-700">
                      {relatedPost.frontmatter.title}
                    </h4>
                    <span class="mt-1 text-[10px] font-semibold uppercase text-pampa-500">Leer articulo</span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}
      </aside>
    </div>
  </main>

  <footer class="border-t border-pampa-50/15 bg-cielo-900 py-8 mt-auto">
    <div class="mx-auto flex w-full max-w-6xl flex-col items-center justify-between gap-4 px-5 sm:flex-row">
      <div>
        <p class="font-headline text-base text-pampa-50">JR Transportes</p>
        <p class="mt-0.5 text-xs text-pampa-50/60">&copy; {new Date().getFullYear()} JR Transportes. Todos los derechos reservados.</p>
      </div>
    </div>
  </footer>

  <script>
    // Menu hamburguesa
    const toggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileIcon = document.getElementById('menu-icon');

    if (toggle && mobileMenu && mobileIcon) {
      toggle.addEventListener('click', () => {
        const open = mobileMenu.classList.toggle('hidden');
        mobileIcon.textContent = open ? 'menu' : 'close';
        toggle.setAttribute('aria-expanded', String(!open));
      });

      mobileMenu.querySelectorAll('.mobile-link').forEach((link) => {
        link.addEventListener('click', () => {
          mobileMenu.classList.add('hidden');
          mobileIcon.textContent = 'menu';
          toggle.setAttribute('aria-expanded', 'false');
        });
      });
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.fade-in-up').forEach((el) => observer.observe(el));
  </script>
</body>
</html>
