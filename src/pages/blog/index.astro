---
import Layout from '../../components/Layout.astro';
import '../../styles/global.css';

const rawPosts = import.meta.glob('../../data/blog/*.md', { eager: true });
const posts = Object.values(rawPosts) as any[];
posts.sort((a, b) => new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf());

const phoneRaw = '51928413201';
const whatsappBase = `https://wa.me/${phoneRaw}`;

const waRoute = `${whatsappBase}?text=${encodeURIComponent(
  'Hola JR Transportes'
)}`;
---

<Layout
  title="Blog de Viajes Ayacucho | JR Transportes"
  description="Blog de viajes con guias, reportajes y consejos para explorar Ayacucho. Descubre destinos turisticos, rutas y experiencias autenticas en el corazon de los Andes."
  keywords="blog viajes Ayacucho, guia turistica Ayacucho, que hacer en Ayacucho, destinos Ayacucho, turismo Ayacucho, viajar a Ayacucho, tips viaje Ayacucho, gastronomia Ayacucho, cultura Ayacucho"
  ogTitle="Blog de Viajes Ayacucho | JR Transportes"
  ogDescription="Blog de viajes con guias, reportajes y consejos para explorar Ayacucho. Descubre destinos turisticos y experiencias autenticas."
  ogType="website"
  ogImage="https://jrtransportesmorochucos.com/images/Pampa%20cangallo/pampa-cangallo.webp"
  activePage="blog"
  ctaText="Contactar"
  ctaHref={waRoute}
>
  <!-- Hero Blog -->
  <section class="relative flex h-[280px] w-full items-end overflow-hidden sm:h-[320px] lg:h-[380px]">
    <img
      src="https://lh3.googleusercontent.com/aida-public/AB6AXuDY7u1kL2Z1wZDsppmSkekS25Q5CEUM500ZfM0TwbLpuE9JB1NCTr6Yl8adRmLAk6icC0aC6oCBUzVdrb18-k2Dj6NyJGsrHtHsmsiZ3hVX6zjUx-Zz-oPShMrtGU81Sk4g72Yj2x2vYQeAcsfdzfBdtHDc5oiHmtSnM7WUkSYdrNAXvVAETkwWkgmiFVZuvLk7Dh5AcOTT7GlKyytJrCI_OkgoIxTcpjnCVzL3E4Bv2VGXudL3Y5cV6UilB4F_uGpFfrjEQHG6pw"
      alt="Paisaje andino de Ayacucho"
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="page-hero-overlay absolute inset-0 bg-gradient-to-t from-pampa-900/85 via-pampa-900/30 to-transparent"></div>

    <div class="relative z-10 mx-auto w-full max-w-6xl px-5 pb-12 sm:pb-14">
      <span class="mb-3 inline-block rounded-full bg-pampa-300 px-4 py-1.5 text-xs font-bold uppercase tracking-[0.12em] text-pampa-800">
        En ruta
      </span>
      <h1 class="font-headline text-4xl text-white sm:text-5xl">
        Blog de Viajes
      </h1>
      <p class="mt-3 max-w-lg text-base leading-relaxed text-pampa-100/85">
        Historias, reportajes y guias para descubrir Ayacucho.
      </p>
    </div>

    <div class="andean-divider absolute bottom-0 left-0 right-0 opacity-40"></div>
  </section>

  <!-- Lista de Articulos -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto w-full max-w-6xl px-5">
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post, i) => (
          <article class={`fade-in-up stagger-${i + 1} group flex flex-col overflow-hidden rounded-xl border border-pampa-200/50 bg-white shadow-soft transition-all duration-300 hover:-translate-y-2 hover:shadow-float`}>
            <div class="relative h-52 overflow-hidden">
              <img
                src={post.frontmatter.image}
                alt={post.frontmatter.title}
                class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
                loading="lazy"
              />
              <span class="absolute left-3 top-3 z-10 rounded-full bg-cielo-700/90 px-3 py-1 text-xs font-extrabold text-white shadow-soft backdrop-blur-md">
                {post.frontmatter.tag}
              </span>
            </div>
            <div class="flex flex-1 flex-col justify-between p-5">
              <div>
                <div class="mb-2 flex items-center gap-2 text-xs font-semibold text-pampa-500">
                  <span>{new Date(post.frontmatter.date).toLocaleDateString('es-PE', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                  <span class="h-1 w-1 rounded-full bg-pampa-300"></span>
                  <span>{post.frontmatter.readingTime}</span>
                </div>
                <h3 class="font-headline text-xl text-pampa-800 leading-tight">{post.frontmatter.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-pampa-700/70 line-clamp-3">{post.frontmatter.description}</p>
              </div>
              <div class="mt-4 flex items-center justify-between">
                <span class="text-xs font-bold uppercase tracking-widest text-pampa-500">Por {post.frontmatter.author}</span>
                <a
                  class="inline-flex items-center gap-1 text-sm font-bold text-cielo-500 no-underline transition-all hover:gap-2 hover:text-cielo-700"
                  href={`/blog/${post.frontmatter.slug}`}
                >
                  Leer
                  <span class="material-symbols-outlined text-base">arrow_forward</span>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Boton flotante WhatsApp -->
  <a
    slot="after-footer"
    class="fixed bottom-5 right-5 z-40 flex items-center gap-2 rounded-full bg-quebrada-500 px-4 py-3 text-sm font-bold text-white no-underline shadow-float transition-all duration-200 hover:-translate-y-0.5 hover:bg-quebrada-400 hover:shadow-elevated"
    href={waRoute}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Abrir WhatsApp"
  >
    <span class="material-symbols-outlined text-lg">chat</span>
    WhatsApp
  </a>
</Layout>
