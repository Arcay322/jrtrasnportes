---
export interface Props {
  activePage?: string;
  ctaText?: string;
  ctaHref?: string;
}

const {
  activePage = '',
  ctaText = 'Reservar ahora',
  ctaHref = 'https://wa.me/51928413201?text=Hola%20JR%20Transportes%2C%20deseo%20consultar%20por%20rutas%20y%20horarios.',
} = Astro.props;

const baseMenu = [
  { label: 'Inicio', href: '/' },
  { label: 'Servicios', href: '/#servicios' },
  { label: 'Destinos', href: '/destinos' },
  { label: 'Blog', href: '/blog' },
];

const menuLinks = activePage === 'index'
  ? [
      { label: 'Inicio', href: '#contenido' },
      { label: 'Servicios', href: '#servicios' },
      { label: 'Destinos', href: '/destinos' },
      { label: 'Blog', href: '/blog' },
      { label: 'Politicas', href: '#politicas' },
      { label: 'Contacto', href: '#contacto' },
    ]
  : baseMenu.concat(activePage === 'destinos' || activePage === 'destino-detail'
      ? [{ label: 'Contacto', href: '/#contacto' }]
      : []);

const isActive = (item: typeof menuLinks[0]) => {
  if (activePage === 'index' && item.href.startsWith('#')) return false;
  if (activePage === 'destinos' && item.label === 'Destinos') return true;
  if (activePage === 'blog' && item.label === 'Blog') return true;
  if (activePage === 'destino-detail' && item.label === 'Destinos') return true;
  if (activePage === 'blog-detail' && item.label === 'Blog') return true;
  return false;
};
---

<!-- Header -->
<header class="andean-border-top sticky top-0 z-50 border-b border-pampa-200/60 bg-pampa-50/80 backdrop-blur-xl">
  <div class="mx-auto flex w-full max-w-6xl items-center justify-between gap-4 px-4 py-2">
    <a href="/" class="no-underline flex items-center -ml-1">
      <img src="/JRlogo.webp" alt="JR Transportes" class="h-14 w-auto object-contain" />
    </a>

    <!-- Navegacion desktop -->
    <nav class="hidden items-center gap-6 md:flex" aria-label="Menu principal">
      {menuLinks.map((item) => (
        <a
          href={item.href}
          class:list={[
            "text-sm font-semibold no-underline transition-colors duration-150",
            isActive(item)
              ? "text-pampa-500 border-b border-pampa-500 pb-0.5"
              : "text-pampa-700/80 hover:text-pampa-500"
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a
        class="hidden rounded-lg bg-logo-500 px-4 py-2 text-sm font-bold text-white no-underline transition-all duration-150 hover:-translate-y-0.5 hover:bg-logo-600 hover:shadow-elevated sm:inline-flex"
        href={ctaHref}
        target="_blank"
        rel="noopener noreferrer"
      >
        {ctaText}
      </a>

      <!-- Boton hamburguesa movil -->
      <button
        id="menu-toggle"
        type="button"
        class="inline-flex items-center justify-center rounded-lg p-2 text-pampa-600 transition-colors hover:bg-pampa-200/50 md:hidden"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label="Abrir menu"
      >
        <span class="material-symbols-outlined" id="menu-icon">menu</span>
      </button>
    </div>
  </div>

  <!-- Menu movil -->
  <nav
    id="mobile-menu"
    class="hidden border-t border-pampa-200/60 bg-pampa-50 px-5 pb-4 pt-2 md:hidden"
    aria-label="Menu movil"
  >
    {menuLinks.map((item) => (
      <a
        href={item.href}
        class="mobile-link block rounded-lg px-3 py-2.5 text-sm font-semibold text-pampa-700 no-underline transition-colors hover:bg-pampa-100"
      >
        {item.label}
      </a>
    ))}
    <a
      class="mt-2 block rounded-lg bg-logo-500 px-3 py-2.5 text-center text-sm font-bold text-white no-underline"
      href={ctaHref}
      target="_blank"
      rel="noopener noreferrer"
    >
      {ctaText}
    </a>
  </nav>
</header>
