---
import SEO from './SEO.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import MobileMenuScript from './MobileMenuScript.astro';

export interface Props {
  title: string;
  description: string;
  keywords?: string;
  author?: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: string;
  ogImage?: string;
  ogLocale?: string;
  ogSiteName?: string;
  twitterCard?: string;
  twitterImage?: string;
  twitterCreator?: string;
  schema?: Record<string, any>;
  activePage?: string;
  ctaText?: string;
  ctaHref?: string;
  showFooterLinks?: boolean;
  footerVariant?: 'dark' | 'blue';
  bodyClass?: string;
  mainClass?: string;
  noIndex?: boolean;
  preloadFonts?: boolean;
}

const {
  title,
  description,
  keywords,
  author,
  canonical,
  ogTitle,
  ogDescription,
  ogType,
  ogImage,
  ogLocale,
  ogSiteName,
  twitterCard,
  twitterImage,
  twitterCreator,
  schema,
  activePage = '',
  ctaText,
  ctaHref,
  showFooterLinks = true,
  footerVariant = 'dark',
  bodyClass = 'bg-pampa-50 selection:bg-pampa-300 selection:text-pampa-900',
  mainClass = '',
  noIndex = false,
  preloadFonts = true,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <!-- Pre-hidratacion de tema: debe ir PRIMERO para evitar flash -->
  <script is:inline>
    (function() {
      const saved = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const isDark = saved === 'dark' || (!saved && prefersDark);
      if (isDark) {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    })();
  </script>
  <SEO
    title={title}
    description={description}
    keywords={keywords}
    author={author}
    canonical={canonical}
    ogTitle={ogTitle}
    ogDescription={ogDescription}
    ogType={ogType}
    ogImage={ogImage}
    ogLocale={ogLocale}
    ogSiteName={ogSiteName}
    twitterCard={twitterCard}
    twitterImage={twitterImage}
    twitterCreator={twitterCreator}
    schema={schema}
    noIndex={noIndex}
    preloadFonts={preloadFonts}
  />
  <script is:inline>
    (function() {
      const meta = document.getElementById('theme-color-meta');
      if (meta) {
        meta.content = document.documentElement.getAttribute('data-theme') === 'dark' ? '#0D1E30' : '#8B6914';
      }
    })();
  </script>

  <style is:inline>
    /* ============================================
       DARK MODE — "La noche cae sobre la pampa"
       ============================================ */

    [data-theme="dark"] { color-scheme: dark; }

    html[data-theme="dark"] {
      /* Pampa: tierra → nocturno. 50/100 oscuros para fondos.
         600-900 iluminados para textos. */
      --color-pampa-50:  #0D1E30;
      --color-pampa-100: #122840;
      --color-pampa-200: #1B3A5C;
      --color-pampa-300: #6B96C7;
      --color-pampa-400: #A3BFE0;
      --color-pampa-500: #D0DFF0;
      --color-pampa-600: #E3D6B8;
      --color-pampa-700: #F2EBD9;
      --color-pampa-800: #FAF6ED;
      --color-pampa-900: #FFFFFF;

      /* Cielo: 700/800/900 MANTENER oscuros para gradientes y fondos.
         500/600 iluminados para links y acentos. */
      --color-cielo-50:  #EDF3FA;
      --color-cielo-100: #D0DFF0;
      --color-cielo-200: #A3BFE0;
      --color-cielo-300: #6B96C7;
      --color-cielo-400: #4B78AA;
      --color-cielo-500: #6B96C7;
      --color-cielo-600: #A3BFE0;
      --color-cielo-700: #1B3A5C;
      --color-cielo-800: #122840;
      --color-cielo-900: #0D1E30;

      /* Quebrada */
      --color-quebrada-400: #6B9E67;
      --color-quebrada-500: #5A8A56;
      --color-quebrada-600: #4A7A46;

      /* Logo */
      --color-logo-400: #E85D5D;
      --color-logo-500: #D62828;
      --color-logo-600: #B51F1F;

      /* Blanco → azul oscuro para superficies */
      --color-white: #1B3A5C;
    }

    /* Fallbacks estaticos que no usan variables */
    [data-theme="dark"] :is(.text-white) { color: #D0DFF0; }
    [data-theme="dark"] :is(.bg-logo-500) { background-color: #D62828; }
    [data-theme="dark"] :is(.bg-quebrada-500) { background-color: #5A8A56; }
    [data-theme="dark"] :is(.text-quebrada-500) { color: #5A8A56; }

    /* HERO: el overlay usa pampa-900 que ahora es blanco.
       Forzar a un gradiente oscuro coherente en dark mode. */
    [data-theme="dark"] .hero-overlay {
      background: linear-gradient(to right, rgba(13, 30, 48, 0.92), rgba(18, 40, 64, 0.75), rgba(13, 30, 48, 0.50)) !important;
    }

    /* CTA final: textos pampa-50/100 sobre fondo oscuro
       deben seguir siendo claros (no invertidos) */
    [data-theme="dark"] .cta-final-section :is(.text-pampa-50) { color: #F2EBD9; }
    [data-theme="dark"] .cta-final-section :is(.text-pampa-50\\/80) { color: rgba(242, 235, 217, 0.80); }
    [data-theme="dark"] .cta-final-section :is(.bg-pampa-300) { background-color: #C4A94D; }
    [data-theme="dark"] .cta-final-section :is(.text-cielo-900) { color: #0D1E30; }

    /* Footer: separador visual mas definido en dark mode */
    [data-theme="dark"] footer { border-top-color: rgba(107, 150, 199, 0.20); }

    /* Textos claros sobre fondos oscuros: forzar a beige
       (pampa-50/100 se invierten a oscuros para fondos,
        pero para textos deben seguir siendo claros) */
    [data-theme="dark"] :is(.text-pampa-50) { color: #F2EBD9; }
    [data-theme="dark"] :is(.text-pampa-50\\/60) { color: rgba(242, 235, 217, 0.60); }
    [data-theme="dark"] :is(.text-pampa-50\\/75) { color: rgba(242, 235, 217, 0.75); }
    [data-theme="dark"] :is(.text-pampa-50\\/80) { color: rgba(242, 235, 217, 0.80); }
    [data-theme="dark"] :is(.text-pampa-50\\/95) { color: rgba(242, 235, 217, 0.95); }
    [data-theme="dark"] :is(.text-pampa-100) { color: #E3D6B8; }
    [data-theme="dark"] :is(.text-pampa-100\\/85) { color: rgba(227, 214, 184, 0.85); }
    [data-theme="dark"] :is(.text-pampa-100\\/90) { color: rgba(227, 214, 184, 0.90); }

    /* Imagenes y mapa */
    [data-theme="dark"] img:not([src*="google.com/maps"]) { filter: brightness(0.88) saturate(0.92); }
    [data-theme="dark"] iframe[src*="google.com/maps"] { filter: invert(0.88) hue-rotate(180deg) contrast(0.85); }

    /* Textura */
    [data-theme="dark"] .noise-overlay { mix-blend-mode: overlay; opacity: 0.08; }
    [data-theme="dark"] .andean-divider { opacity: 0.6; }
    [data-theme="dark"] ::selection { background-color: #3A5F94; color: #F2EBD9; }
  </style>
</head>
<body class={bodyClass}>
  <div class="noise-overlay"></div>
  <a class="skip-link" href="#contenido">Saltar al contenido</a>

  <Header activePage={activePage} ctaText={ctaText} ctaHref={ctaHref} />

  <main id="contenido" class={mainClass}>
    <slot />
  </main>

  <Footer showLinks={showFooterLinks} variant={footerVariant} />

  <slot name="after-footer" />

  <MobileMenuScript />

  <slot name="scripts" />

  <!-- Theme toggle script -->
  <script is:inline>
    (function() {
      const toggle = document.getElementById('theme-toggle');
      const html = document.documentElement;
      const icon = document.getElementById('theme-icon');
      const metaTheme = document.querySelector('meta[name="theme-color"]');

      function updateThemeIcon() {
        if (icon) {
          icon.textContent = html.getAttribute('data-theme') === 'dark' ? 'dark_mode' : 'light_mode';
        }
      }

      function updateMetaTheme() {
        if (metaTheme) {
          metaTheme.content = html.getAttribute('data-theme') === 'dark' ? '#0D1E30' : '#8B6914';
        }
      }

      function disableTransitionsTemporarily() {
        const css = document.createElement('style');
        css.textContent = '*, *::before, *::after { transition: none !important; animation: none !important; }';
        css.id = 'no-theme-transition';
        document.head.appendChild(css);
        // Forzar reflow para que el browser aplique el estilo
        void document.documentElement.offsetHeight;
        // Quitar en el siguiente frame (despues del cambio de tema)
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            css.remove();
          });
        });
      }

      toggle?.addEventListener('click', () => {
        disableTransitionsTemporarily();
        const isDark = html.getAttribute('data-theme') === 'dark';
        if (isDark) {
          html.removeAttribute('data-theme');
          localStorage.setItem('theme', 'light');
        } else {
          html.setAttribute('data-theme', 'dark');
          localStorage.setItem('theme', 'dark');
        }
        updateThemeIcon();
        updateMetaTheme();
      });

      updateThemeIcon();
      updateMetaTheme();
    })();
  </script>

  <!-- Scroll-triggering para animaciones fade-in-up -->
  <script>
    (function() {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, {
        threshold: 0.1,
        rootMargin: '0px 0px -40px 0px'
      });

      document.querySelectorAll('.fade-in-up').forEach((el) => {
        observer.observe(el);
      });
    })();
  </script>
</body>
</html>
